# Define the match conditions for the next match: Vs Man United at home in the Premier League, with rain forecasted, and a loss in the previous match

new_match <- list(
  comp_EFL = 0,     # Premier League
  comp_CL = 0,     # Not Champions League
  comp_FA = 0,     # Not FA Cup
  rain = 1,        # Rainy weather
  home = 1,        # Home match
  result_win = 0,  # Last match was not a win
  result_draw = 0, # Last match was not a draw
  team_rank = 0    # Opponent rank
)

# Extract posterior samples
posterior_samples <- as.matrix(samples)

# Calculate the linear predictor
linear_predictor <- posterior_samples[, "beta0"] +
  posterior_samples[, "beta1"] * new_match$comp_CL +
  posterior_samples[, "beta2"] * new_match$comp_FA +
  posterior_samples[, "beta3"] * new_match$comp_EFL +
  posterior_samples[, "beta4"] * new_match$rain +
  posterior_samples[, "beta5"] * new_match$home +
  posterior_samples[, "beta6"] * new_match$result_win +
  posterior_samples[, "beta7"] * new_match$result_draw +
  posterior_samples[, "beta8"] * new_match$team_rank

# Transform to Poisson rate (lambda)
lambda <- exp(linear_predictor)

# Generate posterior predictive samples for the number of goals
predicted_goals <- rpois(length(lambda), lambda)
prediction_summary <- table(predicted_goals)/length(predicted_goals)

# Construct betting_summary with diagnostic checks
betting_summary <- data.frame(
  
  Goals = as.numeric(names(prediction_summary)),
  Probability = as.numeric(prediction_summary)
)

# Display betting summary
ggplot(betting_summary, aes(x = Goals, y = prediction_summary)) +
  geom_bar(stat = "identity", fill = "steelblue") +
  labs(
    title = "Predicted number of Goals Scored in the next match",
    x = "Number of Goals",
    y = "Probability"
  ) +
  theme_minimal()

